# ─────────────────────────────────────────────────────────────
# UBet configuration. Copy to `.env` for local dev.
# Every value has a sensible default — nothing here is required to run.
# ─────────────────────────────────────────────────────────────

# HTTP port the single service listens on.
PORT=8080

# development | production. Controls logging + static serving.
NODE_ENV=development

# Where the SQLite file lives. On Railway, point this at a mounted
# volume (e.g. /data/ubet.db) so data survives redeploys.
DATABASE_PATH=./data/ubet.db

# Comma-separated allowed CORS origins, or * for any.
# In production with a custom client origin, set this explicitly.
CORS_ORIGIN=*

# Secret used to sign short-lived host-session tokens. Set this in production
# so host sessions survive restarts/redeploys; if unset it rotates per boot
# (hosts just re-enter their PIN after a restart). Use a long random string.
SESSION_SECRET=
# How long a host stays unlocked before re-entering the PIN (ms). Default 8h.
HOST_SESSION_TTL_MS=28800000

# Defaults applied when a host creates a pool (host can override in the UI).
DEFAULT_BUY_IN=20
DEFAULT_CURRENCY=USD

# ── Live data sync (real fixtures + results) ──
# Leave SYNC_PROVIDER blank to use the committed snapshot with host-entered
# results (offline-safe, complete 104-match bracket). Set it to pull REAL
# fixtures + live scores; new pools then auto-score from the feed.
#
#   thesportsdb  → free + keyless. Works out of the box. Coverage depends on
#                  what TheSportsDB has loaded for the season (often partial
#                  until close to / during the tournament).
#   footballdata → most complete + accurate. Needs a free key from
#                  https://football-data.org (set FOOTBALL_DATA_API_KEY).
SYNC_PROVIDER=
FOOTBALL_DATA_API_KEY=
SYNC_INTERVAL_MS=60000
SYNC_SEASON=2026
# TheSportsDB overrides (defaults are fine): key "3" is the shared free key,
# league 4429 = FIFA World Cup.
SPORTSDB_KEY=3
SPORTSDB_LEAGUE=4429

# ── Optional: pull a full fixtures snapshot from a custom URL on first boot ──
# Must return JSON in the shape of server/data/fixtures.json. Lower priority
# than SYNC_PROVIDER. Leave blank to use the committed snapshot.
FIXTURES_API_URL=
FIXTURES_API_KEY=
