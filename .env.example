# ─────────────────────────────────────────────────────────────
# UBet configuration. Copy to `.env` for local dev.
# Every value has a sensible default — nothing here is required to run.
# ─────────────────────────────────────────────────────────────

# HTTP port the single service listens on.
PORT=8080

# development | production. Controls logging + static serving.
NODE_ENV=development

# Where the SQLite file lives. On Railway, point this at a mounted
# volume (e.g. /data/ubet.db) so data survives redeploys.
DATABASE_PATH=./data/ubet.db

# Comma-separated allowed CORS origins, or * for any.
# In production with a custom client origin, set this explicitly.
CORS_ORIGIN=*

# Defaults applied when a host creates a pool (host can override in the UI).
DEFAULT_BUY_IN=20
DEFAULT_CURRENCY=USD

# ── Optional: pull live fixtures instead of the committed snapshot ──
# If set, the server fetches fixtures from this URL on first boot.
# Must return JSON in the shape of server/data/fixtures.json.
# Leave blank to use the committed snapshot (recommended / offline-safe).
FIXTURES_API_URL=
FIXTURES_API_KEY=
