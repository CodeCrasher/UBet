# ─────────────────────────────────────────────────────────────
# UBet configuration. Copy to `.env` for local dev.
# Every value has a sensible default — nothing here is required to run.
# ─────────────────────────────────────────────────────────────

# HTTP port for the single service.
PORT=8080

# development | production. production enables secure cookies + static serving.
NODE_ENV=development

# SQLite file. On Railway, point at a mounted volume (e.g. /data/ubet.db)
# so users, entries and balances survive redeploys.
DATABASE_PATH=./data/ubet.db

# Comma-separated allowed CORS origins, or * for any (single-origin app).
CORS_ORIGIN=*

# Virtual balance (Rs) granted to every new account. No real money — ever.
STARTING_BALANCE=100000

# PIN that gates the admin panel (push live scores, confirm results, settle).
# CHANGE THIS IN PRODUCTION.
ADMIN_PIN=2026

# Session lifetime for the httpOnly login cookie (ms). Default 30 days.
SESSION_TTL_MS=2592000000
