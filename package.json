{
  "name": "ubet",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "UBet — a private FIFA World Cup 2026 prediction pool. Predict scorelines, climb a live leaderboard, win the pot.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently -n server,client -c green,cyan \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "cross-env NODE_ENV=development node --watch server/index.js",
    "dev:client": "vite",
    "build": "vite build",
    "build:fixtures": "node server/data/build-fixtures.mjs",
    "start": "node server/index.js",
    "seed": "node server/seed.js",
    "lint": "eslint .",
    "test": "node --test tests/unit tests/integration",
    "test:e2e": "playwright test",
    "postinstall": "node server/data/build-fixtures.mjs"
  },
  "dependencies": {
    "@preact/signals": "^1.3.0",
    "better-sqlite3": "^11.7.0",
    "compression": "^1.7.5",
    "express": "^4.21.2",
    "nanoid": "^5.0.9",
    "preact": "^10.25.3",
    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.49.1",
    "@preact/preset-vite": "^2.9.3",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "eslint": "^9.17.0",
    "globals": "^15.14.0",
    "socket.io-client": "^4.8.1",
    "vite": "^6.0.7"
  }
}
